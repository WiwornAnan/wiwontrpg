# Production environment variables (set these in Render → Environment, NOT in a file).
# This file only documents what's needed. Do NOT commit real secrets.

# ฐานข้อมูล Postgres — Render กรอกให้เองถ้าใช้ Blueprint, หรือวาง connection string ของ Neon
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# ต้องเป็น production เพื่อเปิด secure cookie + trust proxy + เสิร์ฟหน้าเว็บที่ build แล้ว
NODE_ENV="production"

# ความลับของ session — ตั้งให้ยาว สุ่ม (Render generate ให้ได้)
SESSION_SECRET="change-me-to-a-long-random-string"

# โค้ดลับสำหรับสมัครบัญชี dev
DEV_INVITE_CODE="WIWON-DEV-2569"

# บัญชีแอดมินคนแรก (seed จะสร้างให้อัตโนมัติตอน deploy)
ADMIN_EMAIL="you@example.com"
ADMIN_PASSWORD="a-strong-admin-password"

# ไม่จำเป็นในโหมด same-origin (เว็บกับ API อยู่โดเมนเดียวกัน) — ปล่อยว่างได้
# WEB_ORIGIN="https://wiwonanant.onrender.com"
